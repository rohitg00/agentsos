{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^(Write|Edit)$",
        "description": "Track file changes for agent memory",
        "hooks": [{
          "type": "command",
          "command": "curl -s -X POST http://localhost:3111/api/memory/store -d '{\"agentId\":\"claude-code\",\"content\":\"File modified: $TOOL_INPUT_file_path\",\"role\":\"system\"}'",
          "timeout": 3000,
          "continueOnError": true
        }]
      }
    ],
    "Stop": [
      {
        "description": "Trigger memory reflection on session end",
        "hooks": [{
          "type": "command",
          "command": "curl -s -X POST http://localhost:3111/api/reflect/check -d '{\"agentId\":\"claude-code\",\"sessionId\":\"$SESSION_ID\",\"iterations\":5}'",
          "timeout": 5000,
          "continueOnError": true
        }]
      }
    ]
  }
}
