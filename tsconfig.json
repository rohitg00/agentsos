{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "lib": ["ES2022"],
    "baseUrl": ".",
    "paths": {
      "@agentos/shared": ["packages/shared/src/index.ts"],
      "@agentos/shared/*": ["packages/shared/src/*.ts"]
    }
  },
  "include": ["src/**/*.ts", "packages/*/src/**/*.ts", "e2e/**/*.ts"],
  "exclude": ["node_modules", "dist", "target"]
}
